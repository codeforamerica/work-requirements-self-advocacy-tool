<% content_for :question_title, t("views.location.edit.title") %>

<h1 class="h2"><%= content_for(:question_title) %></h1>

<%= form_with model: @model, url: { action: :update }, data: { turbo: false }, local: true, method: :put, builder: Cfa::Styleguide::CfaFormBuilder do |f| %>
  <%= f.cfa_select(
          :state,
          t("views.location.edit.state_help_text"),
          LocationData::States.dropdown_options,
          required: true,
          include_blank: t("general.select"),
          id: "state_select",
          value: @model.state
        ) %>

  <div id="county_wrapper">
    <%= f.cfa_select(
            :county,
            t("views.location.edit.county_help_text"),
            [],
            required: false,
            include_blank: t("general.select"),
            id: "county_select",
            value: @model.county
          ) %>
  </div>

  <div id="zip_code_wrapper">
    <%= f.cfa_input_field(:zip_code, t("views.location.edit.zip_code_label")) %>
  </div>

  <%= f.submit t("general.continue"), class: "button button--primary" %>
<% end %>

<script>
  document.addEventListener("turbo:load", function () {
    const stateSelect = document.getElementById("screener_state");
    const countyWrapper = document.getElementById("county_wrapper");
    const countySelect = document.getElementById("screener_county");
    const zipCodeWrapper = document.getElementById("zip_code_wrapper");

    if (!stateSelect || !countyWrapper || !countySelect || !zipCodeWrapper) {
      return;
    }

    // Map of state => counties (just names)
    const allCounties = <%= raw LocationData::Counties::ALL_COUNTIES.transform_values { |c| c.transform_values { |v| v[:name] } }.to_json %>;
    // Map of state => office_by ("county" or "zip_code")
    const statesOfficeBy = <%= raw LocationData::States::STATES_INFO.transform_values { |v| v[:office_by].to_s }.to_json %>;

    function clearCountyDropdown() {
      countySelect.innerHTML = "";
      const placeholder = document.createElement("option");
      placeholder.value = "";
      placeholder.textContent = "<%= j t('general.select') %>";
      countySelect.appendChild(placeholder);
    }

    function populateCounties(state, selectedCounty = "") {
      const counties = allCounties[state];

      if (!counties) {
        countyWrapper.style.display = "none";
        countySelect.required = false;
        clearCountyDropdown();
        return;
      }

      countyWrapper.style.display = "block";
      countySelect.required = true;
      clearCountyDropdown();

      Object.entries(counties).forEach(([key, name]) => {
        const option = document.createElement("option");
        option.value = key;
        option.textContent = name;
        if (key === selectedCounty) {
          option.selected = true;
        }
        countySelect.appendChild(option);
      });
    }

    function showOrHideZipCodeInput(state) {
      if (statesOfficeBy[state] === "zip_code") {
        zipCodeWrapper.style.display = "block";
      } else {
        zipCodeWrapper.style.display = "none";
      }
    }

    const selectRequiredMessage = "<%= j t('general.select_required') %>";
    [stateSelect, countySelect].forEach(function(el) {
      el.addEventListener("invalid", function() {
        el.setCustomValidity(selectRequiredMessage);
      });
      el.addEventListener("change", function() {
        el.setCustomValidity("");
      });
    });

    // Initial population
    populateCounties(stateSelect.value, "<%= j @model.county.to_s %>");
    showOrHideZipCodeInput(stateSelect.value);

    // Update counties whenever the state changes
    stateSelect.addEventListener("change", function () {
      populateCounties(stateSelect.value);
      showOrHideZipCodeInput(stateSelect.value);
    });
  });
</script>
