<% content_for :question_title, t("views.location.edit.title") %>

<h1 class="h2"><%= content_for(:question_title) %></h1>

<%= form_with model: @model, url: { action: :update }, data: { turbo: false }, local: true, method: :put, builder: Cfa::Styleguide::CfaFormBuilder do |f| %>

  <%# --- State Dropdown --- %>
  <%= f.cfa_select(
        :state,
        t("views.location.edit.state_help_text"),
        @states,
        required: true,
        include_blank: t("general.select"),
        id: "state_select",
        value: LocationData::States::OPTIONS
      ) %>

  <%# --- County Dropdown --- %>
  <%= f.cfa_select(
        :county,
        t("views.location.edit.county_help_text"),
        @counties,
        required: true,
        include_blank: t("general.select"),
        id: "county_select",
        value: @model.county
      ) %>

  <%= f.submit t("general.continue"), class: "button button--primary" %>
<% end %>

<script>
  document.addEventListener("DOMContentLoaded", function() {
    const stateSelect = document.getElementById("screener_state");
    const countySelect = document.getElementById("screener_county");

    // Counties keyed by state
    const countiesByState = {
      "<%= LocationData::States::NORTH_CAROLINA %>": <%= raw LocationData::Counties::NORTH_CAROLINA.transform_values { |v| v[:name] }.to_json %>
    };

    function clearCountyDropdown() {
      countySelect.innerHTML = "";
      const placeholder = document.createElement("option");
      placeholder.value = "";
      placeholder.textContent = "<%= j t('general.select') %>";
      countySelect.appendChild(placeholder);
    }

    function populateCountiesForState(state, selectedCounty = "") {
      clearCountyDropdown();
      const counties = countiesByState[state];
      if (!counties) return; // no counties for this state

      Object.entries(counties).forEach(([key, name]) => {
        const option = document.createElement("option");
        option.value = key;
        option.textContent = name;
        if (key === selectedCounty) option.selected = true;
        countySelect.appendChild(option);
      });
    }

    // --- Initial population on page load ---
    // Only use @model.county from Rails
    populateCountiesForState(stateSelect.value, "<%= j @model.county.to_s %>");

    // --- On state change ---
    stateSelect.addEventListener("change", function() {
      // Always clear county selection when user changes state
      populateCountiesForState(stateSelect.value); // selectedCounty empty => just blank placeholder
    });
  });
</script>
