<% if flash.any? %>
  <% flash.each do |type, message| %>
    <!-- Remove timedout, which devise also pushes into flash: https://github.com/heartcombo/devise/issues/1777 -->
    <% next if type == "timedout" %>

    <div class="grid" role="alert">
      <div class="flash">
        <p class="flash__message"><%= sanitize message, tags: ['a'], attributes: ['href'] %></p>
        <%= link_to clear_flashes_path, class: "flash__dismiss", "aria-label": "Dismiss" do %>
          <span class="icon icon-close"></span>
        <% end %>
      </div>
    </div>
  <% end %>
<% end %>
