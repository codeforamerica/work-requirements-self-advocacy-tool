<!DOCTYPE html>
<html>
<head>
  <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
  <style>
    /* Email styles need to be inline */
  </style>
</head>

<body style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;">

<%= image_tag attachments["gbh_email_header.png"].url, alt: "GetBenefitsHelp", style: "width: 100%; max-width: 300px; display: block; margin-top: 10px; margin-bottom: 10px;" %>
<hr style="border: none; border-top: 2px solid #034E46; margin: 0;">

<%= yield %>

<% if ENV["SES_CONTACT_LIST"] %>
  <p style="font-size: 12px; color: #666666; margin-top: 20px;">
    <a href="{{amazonSESUnsubscribeUrl}}"><%= t('general.unsubscribe') %></a>
  </p>
<% end %>

</body>
</html>
