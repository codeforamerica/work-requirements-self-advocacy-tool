<%= image_tag attachments["gbh_email_header.png"].url, alt: "GetBenefitsHelp", style: "width: 100%; max-width: 300px; display: block; margin-top: 10px; margin-bottom: 10px;" %>
<hr style="border: none; border-top: 2px solid #034E46; margin: 0;">

<p>
  <%= t('views.screener_mailer.send_screener_results.greeting', first_name: @screener.first_name, last_name: @screener.last_name) %>
</p>

<p>
  <%= t('views.screener_mailer.send_screener_results.attachment_notice') %>
</p>

<hr style="border: none; border-top: 1px solid #C6C6C6; margin: 0;">

<h2 style="font-weight: bold;">
  <%= t('views.screener_mailer.send_screener_results.next_step_heading') %>
</h2>
<p>
  <%= t('views.screener_mailer.send_screener_results.next_step_instructions') %>
</p>
<p>
  <%= t('views.screener_mailer.send_screener_results.reference_code', code: @screener.confirmation_code) %>
</p>

<hr style="border: none; border-top: 1px solid #C6C6C6; margin: 0;">

<h3 style="font-weight: bold;">
  <%= t('views.screener_mailer.send_screener_results.how_to_submit_heading') %>
</h3>
<% state = @screener.state.downcase %>
<% @screener.offices_to_display.each do |office| %>
  <% if office[:subgeography].present? %>
    <p>If you live <%= office[:subgeography] %>:</p>
  <% end %>
  <ol style="line-height: 2;">
    <li>
      <strong><%= t('views.screener_mailer.send_screener_results.online_label') %></strong> <%= t("views.screener_mailer.send_screener_results.online_submit_#{state}_html").html_safe %>
      <br/><br/>
      <%= t('views.screener_mailer.send_screener_results.online_county', website_name: t("views.screener_mailer.send_screener_results.website_name_#{state}"), website: office[:website]) %><%= t('views.screener_mailer.send_screener_results.online_county_with_email', email: office[:email]) if office[:email].present? %>.
    </li>
    <% if office[:mailing_address].present? %>
      <li>
        <strong><%= t('views.screener_mailer.send_screener_results.mail_label') %></strong> <%= t('views.screener_mailer.send_screener_results.mail_instructions') %>
        <br/><br/>
        <div style="font-style: italic;">
          <% office[:mailing_address].split("\n").each do |line| %>
            <%= line %>
            <br/>
          <% end %>
        </div>
      </li>
    <% end %>
    <% if office[:physical_address].present? %>
      <li>
        <strong><%= t('views.screener_mailer.send_screener_results.in_person_label') %></strong> <%= t('views.screener_mailer.send_screener_results.in_person_instructions') %>
        <br/><br/>
        <div style="font-style: italic;">
          <% office[:physical_address].split("\n").each do |line| %>
            <%= line %>
            <br/>
          <% end %>
        </div>
      </li>
    <% end %>
  </ol>
<% end %>

<p>
  <%= t('views.screener_mailer.send_screener_results.questions_intro') %>
</p>

<% @screener.offices_to_display.each do |office| %>
  <% if office[:subgeography].present? %>
    <p>If you live <%= office[:subgeography] %>:</p>
  <% end %>
  <ul style="line-height: 2;">
    <% if office[:website].present? %>
      <li><%= t('views.screener_mailer.send_screener_results.check_website', website: office[:website]) %></li>
    <% end %>
    <% if office[:email].present? %>
      <li><%= t('views.screener_mailer.send_screener_results.email_office', email: office[:email]) %></li>
    <% end %>
    <% if office[:phone].present? %>
      <li><%= t('views.screener_mailer.send_screener_results.call_office', phone: office[:phone]) %></li>
    <% end %>
  </ul>
<% end %>

<h3 style="font-weight: bold;">
  <%= t('views.screener_mailer.send_screener_results.proofs_you_may_need.title') %>
</h3>

<p>
  <%= t('views.screener_mailer.send_screener_results.proofs_you_may_need.help_text') %>
</p>

<ol style="line-height: 2;">
  <% if @screener.is_student_yes? %>
    <%= t('views.screener_mailer.send_screener_results.proofs_you_may_need.student_html') %>
  <% end %>

  <% if @screener.preventing_work_drugs_alcohol_yes? || @screener.preventing_work_medical_condition_yes? %>
    <li>
      <%= t("views.proof_guidance.edit.proof_of_health_condition_html", proof_of_health_form: t("views.proof_guidance.edit.proof_of_health_form_#{state}").html_safe) %>
    </li>
  <% end %>

  <% if @screener.receiving_disability_benefits? %>
    <li>
      <%= t('views.proof_guidance.edit.proof_of_disability_benefits_html') %>
      <ul>
        <% Screener::DISABILITY_BENEFIT_ATTRIBUTES.each do |benefit| %>
          <% if @screener.public_send("#{benefit}_yes?") %>
            <li>
              <%= t("views.disability_benefits.edit.#{benefit}") %>
              <% if benefit == :receiving_benefits_other && @screener.receiving_benefits_write_in.present? %>
                : <%= @screener.receiving_benefits_write_in %>
              <% end %>
            </li>
          <% end %>
        <% end %>
      </ul>
    </li>
  <% end %>

  <% if @screener.is_in_alcohol_treatment_program_yes? %>
    <li>
      <%= t('views.proof_guidance.edit.proof_of_treatment_program_html') %>
    </li>
  <% end %>
</ol>

<p><%= t('general.gbh_team') %></p>

<% if ENV["SES_CONTACT_LIST"] %>
  <p style="font-size: 12px; color: #666666; margin-top: 20px;">
    <a href="{{amazonSESUnsubscribeUrl}}"><%= t('general.unsubscribe') %></a>
  </p>
<% end %>
