<%= t('views.screener_mailer.send_screener_results.greeting', first_name: @screener.first_name, last_name: @screener.last_name) %>

<%= t('views.screener_mailer.send_screener_results.attachment_notice') %>

---

<%= t('views.screener_mailer.send_screener_results.next_step_heading') %>

<%= t('views.screener_mailer.send_screener_results.next_step_instructions') %>

<%= t('views.screener_mailer.send_screener_results.reference_code', code: @screener.confirmation_code) %>

---

<%= t('views.screener_mailer.send_screener_results.how_to_submit_heading') %>
<% state = @screener.state.downcase %>
<% @screener.offices_to_display.each do |office| %>
  <% if office[:subgeography].present? %>

    <%= t("views.screener_mailer.send_screener_results.if_you_live", subgeography: office[:subgeography]) %>
  <% end %>

  1. <%= t('views.screener_mailer.send_screener_results.online_label') %> <%= t("views.screener_mailer.send_screener_results.online_submit_#{state}_text") %>

     <%= t('views.screener_mailer.send_screener_results.online_county', website_name: t("views.screener_mailer.send_screener_results.website_name_#{state}"), website: office[:website]) %><%= " #{t('views.screener_mailer.send_screener_results.online_county_with_email', email: office[:email])}" if office[:email].present? %>.

  <% if office[:mailing_address].present? %>
    2. <%= t('views.screener_mailer.send_screener_results.mail_label') %> <%= t('views.screener_mailer.send_screener_results.mail_instructions') %>

       <%= office[:mailing_address].split("\n").join("\n       ") %>
  <% end %>

  <% if office[:physical_address].present? %>
    3. <%= t('views.screener_mailer.send_screener_results.in_person_label') %> <%= t('views.screener_mailer.send_screener_results.in_person_instructions') %>

       <%= office[:physical_address].split("\n").join("\n       ") %>
  <% end %>
<% end %>

<%= t('views.screener_mailer.send_screener_results.questions_intro') %>

<% @screener.offices_to_display.each do |office| %>
  <% if office[:subgeography].present? %>

    <%= t("views.screener_mailer.send_screener_results.if_you_live", subgeography: office[:subgeography]) %>
  <% end %>
  <% if office[:website].present? %>
    - <%= t('views.screener_mailer.send_screener_results.check_website', website: office[:website]) %>
  <% end %>
  <% if office[:email].present? %>
    - <%= t('views.screener_mailer.send_screener_results.email_office', email: office[:email]) %>
  <% end %>
  <% if office[:phone].present? %>
    - <%= t('views.screener_mailer.send_screener_results.call_office', phone: office[:phone]) %>
  <% end %>
<% end %>

<%= t('views.screener_mailer.send_screener_results.proofs_you_may_need.title') %>

<%= t('views.screener_mailer.send_screener_results.proofs_you_may_need.help_text') %>
<% if @screener.is_student_yes? %>

<%= t('views.screener_mailer.send_screener_results.proofs_you_may_need.student_text') %>
<% end %>
<% if @screener.preventing_work_drugs_alcohol_yes? || @screener.preventing_work_medical_condition_yes? %>

  <%= t("views.screener_mailer.send_screener_results.proofs_you_may_need.health_condition_text", proof_of_health_form: t("views.screener_mailer.send_screener_results.proofs_you_may_need.proof_of_health_form_text_#{state}") ) %>
<% end %>
<% if @screener.receiving_disability_benefits? %>

<%= t('views.screener_mailer.send_screener_results.proofs_you_may_need.disability_benefits_title') %>
<%= t('views.screener_mailer.send_screener_results.proofs_you_may_need.disability_benefits_help_text') %>
<% Screener::DISABILITY_BENEFIT_ATTRIBUTES.each do |benefit| %>
<% if @screener.public_send("#{benefit}_yes?") %>
- <%= t("views.disability_benefits.edit.#{benefit}") %><% if benefit == :receiving_benefits_other && @screener.receiving_benefits_write_in.present? %>: <%= @screener.receiving_benefits_write_in %><% end %>
<% end %>
<% end %>
<% end %>
<% if @screener.is_in_alcohol_treatment_program_yes? %>

<%= t('views.screener_mailer.send_screener_results.proofs_you_may_need.treatment_program_text') %>
<% end %>

<%= t('general.gbh_team') %>
